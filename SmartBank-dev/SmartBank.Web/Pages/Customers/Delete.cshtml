@page "{id:int}"
@model SmartBank.Web.Pages.Customers.DeleteModel
@{
    ViewData["Title"] = "Delete customer";
}

<h3 class="mb-3 text-danger"><i class="bi bi-trash me-2"></i>Delete customer</h3>

<div class="card" style="max-width: 600px;">
    <div class="card-body p-4">
        <p>Are you sure you want to permanently delete this customer record?</p>
        <dl class="row mb-0">
            <dt class="col-sm-4">Name</dt>
            <dd class="col-sm-8">@Model.Input.FirstName @Model.Input.LastName</dd>
            <dt class="col-sm-4">Email</dt>
            <dd class="col-sm-8">@Model.Input.Email</dd>
            <dt class="col-sm-4">Phone</dt>
            <dd class="col-sm-8">@Model.Input.PhoneNumber</dd>
        </dl>

        <form method="post" class="mt-3" data-confirm="This will permanently delete the customer record. Continue?">
            <input type="hidden" asp-for="Input.CustomerId" />
            <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Delete permanently</button>
            <a asp-page="/Customers/Index" class="btn btn-outline-secondary">Cancel</a>
        </form>
    </div>
</div>
