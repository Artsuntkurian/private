@page
@model SmartBank.Web.Pages.Customers.IndexModel
@{
    ViewData["Title"] = "Customers";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0"><i class="bi bi-people me-2"></i>Customers</h3>
    <a asp-page="/Customers/Create" class="btn btn-primary"><i class="bi bi-person-plus me-1"></i>Add customer</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <input type="text" name="search" value="@Model.SearchTerm" class="form-control"
               placeholder="Search by name, email or customer ID" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-primary"><i class="bi bi-search me-1"></i>Search</button>
    </div>
    @if (!string.IsNullOrWhiteSpace(Model.SearchTerm))
    {
        <div class="col-auto">
            <a asp-page="/Customers/Index" class="btn btn-outline-secondary">Clear</a>
        </div>
    }
</form>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-1"></i>@Model.ErrorMessage</div>
}

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Address</th>
                    <th>Linked user</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Customers.Count == 0)
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">No customers found.</td></tr>
                }
                else
                {
                    @foreach (var c in Model.Customers)
                    {
                        <tr>
                            <td>@c.CustomerId</td>
                            <td>@c.FirstName @c.LastName</td>
                            <td>@c.Email</td>
                            <td>@c.PhoneNumber</td>
                            <td>@c.Address</td>
                            <td>#@c.UserId</td>
                            <td class="text-end">
                                <a asp-page="/Accounts/Index" asp-route-customerId="@c.CustomerId" class="btn btn-sm btn-outline-secondary" title="View accounts">
                                    <i class="bi bi-wallet2"></i>
                                </a>
                                <a asp-page="/Customers/Edit" asp-route-id="@c.CustomerId" class="btn btn-sm btn-outline-primary" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-page="/Customers/Delete" asp-route-id="@c.CustomerId" class="btn btn-sm btn-outline-danger" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
