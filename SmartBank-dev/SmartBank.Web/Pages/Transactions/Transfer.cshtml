@page
@model SmartBank.Web.Pages.Transactions.TransferModel
@{
    ViewData["Title"] = "Transfer";
}

<h3 class="mb-3"><i class="bi bi-arrow-left-right me-2"></i>Transfer funds</h3>

<div class="card" style="max-width: 480px;">
    <div class="card-body p-4">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <form method="post" novalidate>
            <div class="mb-3">
                <label asp-for="Input.FromAccountId" class="form-label"></label>
                <input asp-for="Input.FromAccountId" class="form-control" type="number" min="1" />
                <span asp-validation-for="Input.FromAccountId" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Input.ToAccountId" class="form-label"></label>
                <input asp-for="Input.ToAccountId" class="form-control" type="number" min="1" />
                <span asp-validation-for="Input.ToAccountId" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Input.Amount" class="form-label"></label>
                <div class="input-group">
                    <span class="input-group-text">$</span>
                    <input asp-for="Input.Amount" class="form-control" type="number" step="0.01" min="0.01" data-currency />
                </div>
                <span asp-validation-for="Input.Amount" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn btn-primary w-100"><i class="bi bi-arrow-left-right me-1"></i>Transfer</button>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
