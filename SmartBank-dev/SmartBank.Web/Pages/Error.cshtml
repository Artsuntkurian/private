@page
@model SmartBank.Web.Pages.ErrorModel
@{
    ViewData["Title"] = "Error";
}

<div class="text-center py-5">
    <i class="bi bi-exclamation-octagon display-1 text-danger"></i>
    <h2 class="mt-3">Something went wrong</h2>
    <p class="text-muted">An unexpected error occurred while processing your request.</p>
    @if (Model.ShowRequestId)
    {
        <p class="text-muted small">Request ID: <code>@Model.RequestId</code></p>
    }
    <a asp-page="/Index" class="btn btn-primary mt-2">Back to dashboard</a>
</div>
