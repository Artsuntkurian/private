@page
@model SmartBank.Web.Pages.Notifications.IndexModel
@{
    ViewData["Title"] = "Notifications";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0"><i class="bi bi-bell me-2"></i>Customer notifications</h3>
    <a asp-page="/Notifications/Create" class="btn btn-primary"><i class="bi bi-send me-1"></i>Send notification</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-3">
        <input type="number" name="customerId" value="@Model.CustomerId" min="1" class="form-control" placeholder="Customer ID" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-primary"><i class="bi bi-search me-1"></i>Look up</button>
    </div>
</form>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-1"></i>@Model.ErrorMessage</div>
}

@if (Model.Searched)
{
    <div class="card">
        <div class="card-header">Notifications for customer #@Model.CustomerId</div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr><th>Date</th><th>Type</th><th>Message</th><th>Read</th></tr>
                </thead>
                <tbody>
                    @if (Model.Notifications.Count == 0)
                    {
                        <tr><td colspan="4" class="text-center text-muted py-4">No notifications found for this customer.</td></tr>
                    }
                    else
                    {
                        @foreach (var n in Model.Notifications)
                        {
                            <tr>
                                <td>@n.CreatedAt.ToLocalTime().ToString("g")</td>
                                <td><span class="badge text-bg-info">@n.Type</span></td>
                                <td>@n.Message</td>
                                <td>
                                    @if (n.IsRead)
                                    {
                                        <span class="badge text-bg-secondary">Read</span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-primary">Unread</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
}
