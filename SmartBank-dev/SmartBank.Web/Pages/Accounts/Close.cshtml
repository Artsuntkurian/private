@page "{id:int}"
@model SmartBank.Web.Pages.Accounts.CloseModel
@{
    ViewData["Title"] = "Close account";
}

<h3 class="mb-3 text-danger"><i class="bi bi-x-circle me-2"></i>Close account</h3>

<div class="card" style="max-width: 560px;">
    <div class="card-body p-4">
        @if (Model.Account != null)
        {
            <p>Are you sure you want to close this account?</p>
            <dl class="row mb-0">
                <dt class="col-sm-5">Account number</dt>
                <dd class="col-sm-7">@Model.Account.AccountNumber</dd>
                <dt class="col-sm-5">Current balance</dt>
                <dd class="col-sm-7 balance-amount">@Model.Account.Balance.ToString("C")</dd>
            </dl>

            <form method="post" class="mt-3" data-confirm="This will close the account. Continue?">
                <button type="submit" class="btn btn-danger"><i class="bi bi-x-circle me-1"></i>Close account</button>
                <a asp-page="/Accounts/Index" class="btn btn-outline-secondary">Cancel</a>
            </form>
        }
    </div>
</div>
