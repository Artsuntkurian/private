@page
@model SmartBank.Web.Pages.Accounts.CreateModel
@{
    ViewData["Title"] = "Open account";
}

<h3 class="mb-3"><i class="bi bi-plus-circle me-2"></i>Open a new account</h3>

<div class="card" style="max-width: 560px;">
    <div class="card-body p-4">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <form method="post" novalidate>
            <div class="mb-3">
                <label asp-for="Input.CustomerId" class="form-label"></label>
                <input asp-for="Input.CustomerId" class="form-control" type="number" min="1" />
                <span asp-validation-for="Input.CustomerId" class="text-danger small"></span>
                <div class="form-text">Don't know the ID? <a asp-page="/Customers/Index">Look up the customer</a>.</div>
            </div>
            <div class="mb-3">
                <label asp-for="Input.AccountType" class="form-label"></label>
                <select asp-for="Input.AccountType" class="form-select">
                    <option value="">-- Select account type --</option>
                    @foreach (var type in Model.AccountTypeOptions)
                    {
                        <option value="@type">@type</option>
                    }
                </select>
                <span asp-validation-for="Input.AccountType" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Input.InitialDeposit" class="form-label"></label>
                <div class="input-group">
                    <span class="input-group-text">$</span>
                    <input asp-for="Input.InitialDeposit" class="form-control" type="number" step="0.01" min="0" data-currency />
                </div>
                <span asp-validation-for="Input.InitialDeposit" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary"><i class="bi bi-check2-circle me-1"></i>Open account</button>
                <a asp-page="/Accounts/Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
