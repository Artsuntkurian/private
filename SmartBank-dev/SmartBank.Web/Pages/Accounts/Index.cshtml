@page
@model SmartBank.Web.Pages.Accounts.IndexModel
@{
    ViewData["Title"] = "Accounts";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0"><i class="bi bi-wallet2 me-2"></i>Accounts</h3>
    <a asp-page="/Accounts/Create" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>Open new account</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-3">
        <input type="number" name="customerId" value="@Model.CustomerId" min="1" class="form-control" placeholder="Customer ID" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-primary"><i class="bi bi-search me-1"></i>Look up accounts</button>
    </div>
    <div class="col-auto">
        <a asp-page="/Customers/Index" class="btn btn-outline-secondary">Find customer ID</a>
    </div>
</form>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-1"></i>@Model.ErrorMessage</div>
}

@if (Model.Searched)
{
    <div class="card">
        <div class="card-header">Accounts for customer #@Model.CustomerId</div>
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>Account ID</th>
                        <th>Account number</th>
                        <th>Balance</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Accounts.Count == 0)
                    {
                        <tr><td colspan="5" class="text-center text-muted py-4">No accounts found for this customer.</td></tr>
                    }
                    else
                    {
                        @foreach (var acc in Model.Accounts)
                        {
                            <tr>
                                <td>@acc.AccountId</td>
                                <td>@acc.AccountNumber</td>
                                <td class="balance-amount">@acc.Balance.ToString("C")</td>
                                <td>
                                    @if (acc.IsActive)
                                    {
                                        <span class="badge text-bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge text-bg-secondary">Closed</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <a asp-page="/Transactions/Statement" asp-route-accountId="@acc.AccountId" class="btn btn-sm btn-outline-secondary">Statement</a>
                                    @if (acc.IsActive)
                                    {
                                        <a asp-page="/Accounts/Close" asp-route-id="@acc.AccountId" class="btn btn-sm btn-outline-danger">Close</a>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
}
